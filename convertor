
import xml.etree.ElementTree as ET
from docx import Document
import sys

def xml_to_docx(xml_file, docx_file):
    try:
        # Parse XML
        tree = ET.parse(xml_file)
        root = tree.getroot()

        # Create new Word document
        document = Document()
        document.add_heading("Converted XML Document", level=1)
        document.add_paragraph(" ")

        # Recursive function to extract XML text
        def walk_xml(element, level=0):
            indent = "   " * level
            text = element.text.strip() if element.text else ""

            # Add the element tag and text
            if text:
                document.add_paragraph(f"{indent}{element.tag}: {text}")
            else:
                document.add_paragraph(f"{indent}{element.tag}:")

            # Process children elements
            for child in element:
                walk_xml(child, level + 1)

            # Tail text if any
            if element.tail and element.tail.strip():
                document.add_paragraph(f"{indent}{element.tail.strip()}")

        # Start processing XML
        walk_xml(root)

        # Save Word file
        document.save(docx_file)
        print(f"Conversion successful! Saved as: {docx_file}")

    except Exception as e:
        print(f"Error: {e}")


# Allow running from command line
if __name__ == "__main__":
    if len(sys.argv) != 3:
        print("Usage: python xml_to_docx.py input.xml output.docx")
    else:
        xml_to_docx(sys.argv[1], sys.argv[2])
